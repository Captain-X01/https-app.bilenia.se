# Kopiera till .env.local-dev (eller .env) för lokal dev-build mot enhet/emulator.
# Används av: npm run build:web:dev / build:android:dev
#
# cp .env.local-dev.example .env.local-dev

FRONTEND_GIT_URL=https://github.com/Captain-X01/bilenia-dealer-panel.git
# Under aktiv native-utveckling:
FRONTEND_REF=epic/mobile_app
# Efter merge till prod-linje, byt till:
# FRONTEND_REF=main_proxy

# Kör `npm run print:api-host` för förslag på LAN-IP
VITE_API_BASE_URL=http://YOUR_LAN_IP:5000/api/v1
VITE_API_BASE_URL_SOCKET_IO=http://YOUR_LAN_IP:5000
VITE_WEB_APP_URL=http://localhost:8080
VITE_ENV=development
