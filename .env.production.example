# Mobil-shell prod-build — kopiera till .env.production
# Används endast av: npm run build:android:prod / build:web:prod
#
# Detta är INTE samma fil som backend-serverns .env!
# Backend .env innehåller t.ex. Didit, databas, JWT-hemligheter m.m.
# Här behövs bara det som bakas in i React/Capacitor-appen (VITE_*):

FRONTEND_GIT_URL=https://github.com/Captain-X01/bilenia-dealer-panel.git
# Efter merge av epic/mobile_app → main_proxy, peka hit för stabila store-byggen:
# FRONTEND_REF=main_proxy
# Under utveckling av native kan ni tillfälligt använda:
FRONTEND_REF=epic/mobile_app

# Production API (HTTPS required for Play Store / App Store)
VITE_API_BASE_URL=https://bilenia-backend-47zeo.ondigitalocean.app/api/v1
VITE_API_BASE_URL_SOCKET_IO=https://bilenia-backend-47zeo.ondigitalocean.app
VITE_WEB_APP_URL=https://app.bilenia.se
VITE_ENV=production

# Store-formulär (laddas inte av appen — bara referens):
# Privacy policy URL: https://app.bilenia.se/privacy
# Support URL: https://app.bilenia.se/contact
