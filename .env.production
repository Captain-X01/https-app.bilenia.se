# Prod mobil-build — används av: npm run build:android:prod
# Värden bakas in i appen vid build (läses inte på telefonen).

FRONTEND_GIT_URL=https://github.com/Captain-X01/bilenia-dealer-panel.git
FRONTEND_REF=main_proxy

# Production API — https://api.bilenia.se/ svarar "Car Auction API is running"
VITE_API_BASE_URL=https://api.bilenia.se/api/v1
VITE_API_BASE_URL_SOCKET_IO=https://api.bilenia.se
VITE_WEB_APP_URL=https://app.bilenia.se
VITE_ENV=production
