# Git-URL till bilenia-dealer-panel (SSH eller HTTPS)
FRONTEND_GIT_URL=https://github.com/Captain-X01/bilenia-dealer-panel.git

# Valfritt: branch, tag eller commit (t.ex. mobile-v1.0.0 eller main)
# FRONTEND_REF=mobile-v1.0.0
# FRONTEND_REF=epic/mobile_app
FRONTEND_REF=main_proxy

# Lokal frontend-checkout (för utveckling — redigera här, inte bara i .frontend/)
# FRONTEND_LOCAL_PATH=C:\DevStuff\BEA\bilenia-dealer-panel
# Valfritt: om React bygger till annat än dist/ (t.ex. build för CRA)
# FRONTEND_OUT_DIR=dist

# Fysisk telefon: kör `npm run print:api-host` och använd din PCs WiFi-IP
# Emulator: http://10.0.2.2:5000  |  USB+adb reverse: http://localhost:5000
VITE_API_BASE_URL=http://192.168.1.223:5000/api/v1
VITE_API_BASE_URL_SOCKET_IO=http://192.168.1.223:5000
VITE_WEB_APP_URL=https://app.bilenia.se

## CLOUD BACKEND
# VITE_API_BASE_URL=https://bilenia-backend-47zeo.ondigitalocean.app/api/v1


## Environment
VITE_ENV=development